{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/per-tool.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "model": "claude-haiku-4-5-20251001",
            "timeout": 20,
            "prompt": "Read ${CLAUDE_PLUGIN_ROOT}/prompts/stop.md and follow those instructions exactly. The hook payload is: $ARGUMENTS"
          }
        ]
      }
    ]
  }
}
